# Copy to .env and fill in. Loaded automatically from the working directory at
# startup; real environment variables always take precedence over this file.

# UniFi Protect connection (required). Use a local, read-only account.
UNIFI_HOST=https://192.168.1.1
UNIFI_USERNAME=readonly-user
UNIFI_PASSWORD=change-me

# Optional tuning (defaults shown). Every flag has a UNIFI_* variable; see
# `serve --help`.
# UNIFI_TIMEOUT=5s
# UNIFI_MIN_DETECTION_SPAN=1m
# UNIFI_WEB_LISTEN_ADDRESSES=:9090
# UNIFI_LABELS=<deviceID>=room:kitchen
# LOG_LEVEL=info
